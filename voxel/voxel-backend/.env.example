# Voxel Backend Environment Template
# Copy this file to `.env` and fill secrets.

# ── App ───────────────────────────────────────────────────────────────────────
DEBUG=false
PORT=8000

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:3001","https://voxel.vercel.app"]

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# ── HuggingFace ───────────────────────────────────────────────────────────────
HF_TOKEN=hf_your_token_here
MODEL_CACHE_DIR=/app/models
HF_INFERENCE_API_URL=https://router.huggingface.co/hf-inference/models

# ── ASR routing ───────────────────────────────────────────────────────────────
# auto | modal | inference | local
ASR_EN_STRATEGY=modal

# Modal ASR endpoint
ASR_MODAL_URL=https://your-workspace--voxel-voice-endpoints-fastapi-app.modal.run/asr/transcribe
ASR_MODAL_TOKEN=
ASR_MODAL_TIMEOUT_S=90

# HF and local model options
HF_ASR_INFERENCE_MODEL_EN=openai/whisper-small
HF_ASR_CDLI_EN=openai/whisper-small
HF_ASR_MODEL_EN=openai/whisper-small
HF_ASR_MODEL_EN_ALT=openai/whisper-base
HF_ASR_MODEL_LG=facebook/mms-1b-all

# ── Translation routing ───────────────────────────────────────────────────────
# auto | modal | local
TRANSLATE_STRATEGY=modal
TRANSLATE_MODAL_EN_LG_URL=https://your-workspace--voxel-voice-endpoints-fastapi-app.modal.run/translate
TRANSLATE_MODAL_LG_EN_URL=https://your-workspace--voxel-voice-endpoints-fastapi-app.modal.run/translate
TRANSLATE_MODAL_TOKEN=
TRANSLATE_MODAL_TIMEOUT_S=45

# Local translation models
HF_TRANSLATE_EN_LG=Helsinki-NLP/opus-mt-en-lg
HF_TRANSLATE_LG_EN=Helsinki-NLP/opus-mt-lg-en

# ── TTS routing ───────────────────────────────────────────────────────────────
# auto | modal | local
TTS_STRATEGY=modal
TTS_MODAL_URL=https://your-workspace--voxel-voice-endpoints-fastapi-app.modal.run/tts/synthesize
TTS_MODAL_TOKEN=
TTS_MODAL_TIMEOUT_S=90

# Local TTS models
HF_TTS_EN=facebook/mms-tts-eng
HF_TTS_LG=facebook/mms-tts-lug

# ── OpenAI / LLM ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key
LLM_MODEL=gpt-4o-mini

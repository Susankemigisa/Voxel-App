# ── App ───────────────────────────────────────────────────────────────────────
DEBUG=false
PORT=8000

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=["http://localhost:3000","https://voxel.vercel.app"]

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret          # From Supabase → Settings → API → JWT Secret

# ── HuggingFace ───────────────────────────────────────────────────────────────
HF_TOKEN=hf_your_token_here                  # Required for gated models
MODEL_CACHE_DIR=/app/models                  # Railway persistent volume path

# ASR models (override defaults if needed)
# HF_ASR_MODEL_EN=facebook/wav2vec2-large-xlsr-53
# HF_ASR_MODEL_LG=facebook/mms-300m

# Translation models
# HF_TRANSLATE_EN_LG=Helsinki-NLP/opus-mt-en-lg
# HF_TRANSLATE_LG_EN=Helsinki-NLP/opus-mt-lg-en

# TTS models
# HF_TTS_EN=facebook/mms-tts-eng
# HF_TTS_LG=facebook/mms-tts-lug

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key-here
# LLM_MODEL=gpt-4o-mini                    # default (cheapest + fast)

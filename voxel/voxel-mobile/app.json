{
  "expo": {
    "name": "Voxel",
    "slug": "voxel-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#080d1a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.cdli.voxelmobile",
      "icon": "./assets/icon.png"
    },
    "android": {
      "package": "com.cdli.voxelmobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0b9488"
      },
      "icon": "./assets/icon.png",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.INTERNET",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-av",
        {
          "microphonePermission": "Allow Voxel to access your microphone for voice input."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Voxel to use your location to calculate accurate travel times."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Voxel to access your photos to set a profile picture.",
          "cameraPermission": "Allow Voxel to use the camera for your profile picture."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "ea7ffbde-4d30-4fd1-9827-a1f4f1adc55d"
      }
    },
    "owner": "kemigisa"
  }
}
